# Sonave secrets — copy to `.env` and fill in. `.env` is gitignored (never commit keys).
# Load into your shell before running the service, e.g. (PowerShell):
#   Get-Content .env | ForEach-Object { if ($_ -match '^\s*([^#=]+)=(.*)$') { $env:$($matches[1].Trim())=$matches[2].Trim() } }
# or on bash:  export $(grep -v '^#' .env | xargs)

# --- Recall.ai (Phase 3 capture layer) ---
SONAVE_RECALL_API_KEY=your_recall_api_key_here
# Recall region base URL (see your Recall dashboard; e.g. us-west-2, eu-central-1)
SONAVE_RECALL_BASE=https://us-west-2.recall.ai/api/v1
# LIVE real-time audio streams over a WEBSOCKET. Public wss:// URL to /api/ws/audio.
# With ngrok:  ngrok http 8000  ->  wss://<id>.ngrok.app/api/ws/audio  (note: wss, not https)
SONAVE_RECALL_WS=wss://your-host.example.com/api/ws/audio
# Optional: async lifecycle webhooks (post-call forensic reports) -> Svix endpoint URL
SONAVE_RECALL_WEBHOOK=https://your-host.example.com/api/recall/webhook

# --- Detector thresholds (optional overrides) ---
# SONAVE_TAU_REAL=0.40
# SONAVE_TAU_FAKE=0.70

# --- Alerts / wire-hold (optional) ---
# SONAVE_ALERT_WEBHOOK=https://hooks.slack.com/services/...
# SONAVE_HOLD_WEBHOOK=https://payments.internal/hold
